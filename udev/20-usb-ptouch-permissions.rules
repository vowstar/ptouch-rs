#
# udev rules for Brother P-Touch printers
# Install to /etc/udev/rules.d/ and run: udevadm control --reload-rules
#
# Brother USB Vendor ID: 0x04f9

# PT-9200DX
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2001", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2002", MODE="0660", TAG+="uaccess"
# PT-2300
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2004", MODE="0660", TAG+="uaccess"
# PT-2420PC
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2007", MODE="0660", TAG+="uaccess"
# PT-2450PC
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2011", MODE="0660", TAG+="uaccess"
# PT-18R
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="201a", MODE="0660", TAG+="uaccess"
# PT-1950
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2019", MODE="0660", TAG+="uaccess"
# PT-2700
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="201f", MODE="0660", TAG+="uaccess"
# PT-1230PC
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="202c", MODE="0660", TAG+="uaccess"
# PT-2430PC
