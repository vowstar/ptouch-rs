# PT-E550W
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2060", MODE="0660", TAG+="uaccess"
# PT-P700
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2061", MODE="0660", TAG+="uaccess"
# PT-P750W
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2062", MODE="0660", TAG+="uaccess"
# PT-D410
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="20df", MODE="0660", TAG+="uaccess"
# PT-D450
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2073", MODE="0660", TAG+="uaccess"
# PT-D460BT
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="20e0", MODE="0660", TAG+="uaccess"
# PT-D600
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ATTR{idProduct}=="2074", MODE="0660", TAG+="uaccess"
